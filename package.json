{
  "name": "kshell",
  "version": "0.1.0",
  "description": "一個類似 Xshell 的 SSH 終端工具，支援 Xshell session 導入與主密碼保險庫。",
  "main": "src/main/main.js",
  "author": "jokerjkeeper",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "electron": "^33.0.0"
  },
  "build": {
    "appId": "com.jokerjkeeper.kshell",
    "productName": "kshell",
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
